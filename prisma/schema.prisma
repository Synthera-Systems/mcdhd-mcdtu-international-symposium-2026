generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // Uncomment if using Supabase pooling
}

// --- ENUMS ---
enum DelegateCategory {
  STUDENT
  FACULTY
  INDUSTRY
  FOREIGN
}

enum PaymentStatus {
  PROCESSING         // The AI is currently analyzing it
  ACTION_REQUIRED    // AI failed, user must re-upload via magic link
  PENDING_APPROVAL   // AI passed, waiting for Admin
  COMPLETED          // Admin approved
  FAILED             // Admin fully rejected
}

// --- MODELS ---
model Delegate {
  id                String           @id @default(uuid())
  referenceId       String           @unique
  fullName          String
  affiliation       String
  email             String           @unique
  category          DelegateCategory
  participationType String           @default("GENERAL_ATTENDEE") // GENERAL_ATTENDEE, ORAL_PRESENTER, POSTER_PRESENTER
  linkedAbstractId  String?          // The ABS-XXXXXX-26 ID, if they have one
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  payment           Payment?
}

model Payment {
  id              String        @id @default(uuid())
  delegateId      String        @unique
  utrNumber       String        @unique
  screenshotUrl   String        
  status          PaymentStatus @default(PROCESSING) // Starts in Processing
  actionToken     String?       @unique // Secret UUID for the email link
  aiValidationLog String?       
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  delegate        Delegate      @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model Submission {
  id             String   @id @default(uuid())
  referenceId    String   @unique // ABS-XXXXXX-26
  title          String
  authors        String
  presenterEmail String   // CRITICAL: We need this to link to Delegate!
  type           String   // Oral Presentation or Poster Presentation
  fileUrl        String
  status         String   @default("PENDING_REVIEW") // PENDING_REVIEW, ACCEPTED_ORAL, ACCEPTED_POSTER, REJECTED
  createdAt      DateTime @default(now())
}