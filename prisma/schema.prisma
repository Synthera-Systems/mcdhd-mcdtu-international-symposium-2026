generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// --- ENUMS ---
enum DelegateCategory {
  STUDENT
  FACULTY
  INDUSTRY
  FOREIGN
}

enum PaymentStatus {
  PROCESSING         
  ACTION_REQUIRED    
  PENDING_APPROVAL   
  COMPLETED          
  FAILED             
}

// --- MODELS ---

// NEW: Admin User Table for audit logs and individual logins
model AdminUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Note: For production, hash this. For manual Prisma Studio entry, plaintext is okay temporarily.
  name      String
  role      String   @default("System Administrator")
  createdAt DateTime @default(now())
}

model Delegate {
  id                String           @id @default(uuid())
  referenceId       String           @unique
  fullName          String
  affiliation       String
  email             String           @unique
  category          DelegateCategory
  participationType String           @default("GENERAL_ATTENDEE") 
  linkedAbstractId  String?          
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  payment           Payment?
}

model Payment {
  id              String        @id @default(uuid())
  delegateId      String        @unique
  utrNumber       String        @unique
  screenshotUrl   String        
  status          PaymentStatus @default(PROCESSING) 
  actionToken     String?       @unique 
  aiValidationLog String?       
  reviewedBy      String?       // NEW: Audit log trail
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  delegate        Delegate      @relation(fields: [delegateId], references: [id], onDelete: Cascade)
}

model Submission {
  id             String   @id @default(uuid())
  referenceId    String   @unique 
  title          String
  authors        String
  presenterEmail String   
  type           String   
  fileUrl        String
  status         String   @default("PENDING_REVIEW") 
  reviewedBy     String?  // NEW: Audit log trail
  createdAt      DateTime @default(now())
}